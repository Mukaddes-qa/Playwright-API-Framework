{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",

    "types": [
      "node"
    ],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  },

  "include": [
    "api",
    "config",
    "schemas",
    "tests",
    "types",
    "utils",
    


    "test-data"
  ]
}
